{
  "name": "koi-bus-node-api",
  "version": "2.0.0",
  "description": "Koi Bus Backend API v2",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:e2e": "ts-node prisma/seed-e2e.ts",
    "telemetry:emulator": "ts-node tools/telemetry-device-emulator.ts",
    "docker:up": "podman compose -f ../../docker-compose.yml up -d",
    "docker:down": "podman compose -f ../../docker-compose.yml down",
    "docker:build": "podman compose -f ../../docker-compose.yml build",
    "docker:rebuild": "podman compose -f ../../docker-compose.yml up --build -d",
    "docker:logs": "podman compose -f ../../docker-compose.yml logs -f",
    "db:fresh": "npm run prisma:reset -- --force && npm run prisma:migrate && npm run prisma:seed",
    "db:seed": "npm run prisma:seed",
    "simulate-trip": "ts-node scripts/simulate-trip.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
