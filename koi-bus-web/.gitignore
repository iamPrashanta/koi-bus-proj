.env
.env.*
!.env.example

# ── Next.js build output ──────────────────────────────────────
.next/
out/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Dev launcher PID files ───────────────────────────────────
.pids/

# ── Playwright & QA Testing Artifacts ────────────────────────
qa/playwright-report/
qa/test-results/
qa/artifacts/
qa/blob-report/
qa/.playwright/
playwright-report/
test-results/
coverage/

# ── Database & Data files ─────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-journal
dump.rdb
redis-data/
postgres-data/

# ── Transport data (raw CSVs are large) ───────────────────────
transport-data/**/*.csv
!transport-data/metadata/

# ── IDE & Editor ──────────────────────────────────────────────
.vscode/
.idea/
.gemini/
*.swp
*.swo
